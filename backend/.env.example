# ============================================================
# DocGen Pro — Backend Environment Configuration
# Copy to .env — NEVER commit .env to git
# ============================================================

# REQUIRED — generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_random_hex

# Database
DATABASE_URL=sqlite:///./docgen.db

# File storage
OUTPUT_DIR=./output
TEMPLATE_DIR=./template_store
LOGO_DIR=./uploads/logos

# CORS — exact frontend URL only
CORS_ORIGINS=http://localhost:5173

# Environment: development | production
ENVIRONMENT=development

# Demo accounts — set false in production
ALLOW_DEMO_SEED=true
SEED_ADMIN_PASSWORD=change_this_now
SEED_STAFF_PASSWORD=change_this_now

# Microsoft Word path (Windows only — for PDF generation)
# Leave blank to skip PDF; download DOCX instead
WORD_PATH=
