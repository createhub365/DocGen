# ============================================================
# DocGen Pro — Backend Environment Configuration
# Copy to .env — NEVER commit .env to git
# ============================================================

# REQUIRED — generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_random_hex

# Database
# Local SQLite (default):
# DATABASE_URL=sqlite:///./docgen.db
#
# Supabase PostgreSQL — DocGen project:
# https://azhajzsruwvnffuwlvmy.supabase.co
# Prefer Session pooler on Render (port 5432), not direct db host:
# DATABASE_URL=postgresql://postgres.azhajzsruwvnffuwlvmy@aws-0-[region].pooler.supabase.com:5432/postgres
# DATABASE_PASSWORD=your_supabase_db_password
# (Use DATABASE_PASSWORD when the password contains @, #, %, etc.)
# Or encode special chars in the URL: @ → %40, # → %23, % → %25
DATABASE_URL=sqlite:///./docgen.db

# File storage
OUTPUT_DIR=./output
TEMPLATE_DIR=./template_store
LOGO_DIR=./uploads/logos

# Supabase Storage (recommended on Render — survives redeploy)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Buckets auto-created: employer-logos, template-thumbnails, template-documents

# CORS — comma-separated frontend URLs (Cloudflare + local dev)
CORS_ORIGINS=http://localhost:5173,https://docgen.createhub365.workers.dev

# Environment: development | production
ENVIRONMENT=development

# Demo accounts — set false in production
ALLOW_DEMO_SEED=true
SEED_ADMIN_PASSWORD=change_this_now
SEED_STAFF_PASSWORD=change_this_now

# Microsoft Word path (Windows only — for PDF generation)
# Leave blank to skip PDF; download DOCX instead
WORD_PATH=
